# --- HubSpot ---
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_OWNER_ID=

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Fireflies ---
FIREFLIES_API_KEY=

# --- Auth: Google Workspace login (primary method) ---
# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Your exact Workspace domain, e.g. leadfox.io — only these accounts can log in.
# NE JAMAIS laisser vide en production.
GOOGLE_WORKSPACE_DOMAIN=

# Secret used by NextAuth to sign sessions. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the app, required by NextAuth in production.
NEXTAUTH_URL=https://leadfox-sales-hub.vercel.app

# --- Auth: shared password (fallback method) ---
APP_PASSWORD=
