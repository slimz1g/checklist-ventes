# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- HubSpot ---
# Create a Private App in HubSpot (Settings > Integrations > Private Apps) with
# scopes: crm.objects.deals.read, crm.objects.contacts.read, crm.objects.owners.read,
# crm.objects.tasks.read, crm.schemas.deals.read
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=2530556
HUBSPOT_OWNER_ID=396827993

# --- Google Sheets ---
# Create a Service Account in Google Cloud Console, enable the Sheets API,
# download the JSON key, then paste its full contents here as a single-line string.
# Share the "Objectif 2026 (marketing-vente)" sheet with the service account's
# client_email (found inside the JSON key) so it can read it.
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Fireflies ---
# Get your API key from Fireflies.ai > Settings > Developer Settings
FIREFLIES_API_KEY=
